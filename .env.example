# CoinGecko (optional — free tier works without key)
COINGECKO_API_KEY=
 
# Google Sheets (required)
GOOGLE_CREDENTIALS_JSON=/path/to/service_account.json
GOOGLE_SHEET_ID=your_sheet_id_here
 
# Storage paths (optional — defaults shown)
CSV_PATH=data/market_data.csv
SQLITE_PATH=data/market_data.db
 
# Pipeline
PIPELINE_VERSION=1.0.0
ENABLE_SHEETS=true
ENABLE_CSV=true
ENABLE_SQLITE=true
